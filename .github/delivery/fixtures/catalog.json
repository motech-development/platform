{
  "units": [
    {
      "id": "component-library",
      "workspace": "@motech-development/breeze-ui",
      "path": "packages/breeze-ui",
      "targets": ["production"],
      "dependsOn": [],
      "expectedStacks": [],
      "exception": "Publishes the Storybook site to GitHub Pages rather than CloudFormation."
    },
    {
      "id": "core-anti-virus",
      "workspace": "@core/anti-virus",
      "path": "applications/core/anti-virus",
      "targets": ["preview", "develop", "production"],
      "dependsOn": [],
      "expectedStacks": ["anti-virus-{stage}"]
    },
    {
      "id": "core-infrastructure",
      "workspace": "@core/infrastructure",
      "path": "applications/core/infrastructure",
      "targets": ["production"],
      "dependsOn": [],
      "expectedStacks": ["platform-{stage}-infrastructure"]
    },
    {
      "id": "core-communications",
      "workspace": "@core/comms",
      "path": "applications/core/comms",
      "targets": ["production"],
      "dependsOn": ["core-infrastructure"],
      "expectedStacks": ["platform-{stage}-comms"]
    },
    {
      "id": "accounts-infrastructure",
      "workspace": "@accounts/infrastructure",
      "path": "applications/accounts/infrastructure",
      "targets": ["production"],
      "dependsOn": ["core-infrastructure"],
      "expectedStacks": ["accounts-{stage}-infrastructure"]
    },
    {
      "id": "accounts-storage",
      "workspace": "@accounts/storage",
      "path": "applications/accounts/storage",
      "targets": ["preview", "develop", "production"],
      "dependsOn": ["core-anti-virus"],
      "expectedStacks": ["accounts-{stage}-storage"]
    },
    {
      "id": "accounts-data",
      "workspace": "@accounts/data",
      "path": "applications/accounts/data",
      "targets": ["preview", "develop", "production"],
      "dependsOn": ["accounts-storage", "core-anti-virus"],
      "expectedStacks": ["accounts-{stage}-data"]
    },
    {
      "id": "accounts-notifications",
      "workspace": "@accounts/notifications",
      "path": "applications/accounts/notifications",
      "targets": ["preview", "develop", "production"],
      "dependsOn": ["accounts-data"],
      "expectedStacks": ["accounts-{stage}-notifications"]
    },
    {
      "id": "accounts-queue",
      "workspace": "@accounts/queue",
      "path": "applications/accounts/queue",
      "targets": ["preview", "develop", "production"],
      "dependsOn": ["accounts-data"],
      "expectedStacks": ["accounts-{stage}-queue"]
    },
    {
      "id": "accounts-reports",
      "workspace": "@accounts/reports",
      "path": "applications/accounts/reports",
      "targets": ["preview", "develop", "production"],
      "dependsOn": [
        "accounts-data",
        "accounts-notifications",
        "accounts-storage"
      ],
      "expectedStacks": ["accounts-{stage}-reports"]
    },
    {
      "id": "accounts-api",
      "workspace": "@accounts/api",
      "path": "applications/accounts/api",
      "targets": ["preview", "develop", "production"],
      "dependsOn": [
        "accounts-data",
        "accounts-queue",
        "accounts-reports",
        "accounts-storage"
      ],
      "expectedStacks": ["accounts-{stage}-api"]
    },
    {
      "id": "accounts-client",
      "workspace": "@accounts/client",
      "path": "applications/accounts/client",
      "targets": ["production"],
      "dependsOn": ["accounts-api", "accounts-infrastructure"],
      "expectedStacks": [],
      "exception": "Publishes static assets into the accounts infrastructure without owning a CloudFormation stack."
    }
  ]
}
