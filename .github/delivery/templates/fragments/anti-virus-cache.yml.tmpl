      - name: Start ClamAV timing
        id: clamav-timing
        run: echo "cache-started-at=$(date +%s)" >> "$GITHUB_OUTPUT"

      - name: Check ClamAV binary cache compatibility
        id: clamav-cache
        shell: bash
        run: |
          if [[ -f applications/core/anti-virus/build-inputs.env && -x applications/core/anti-virus/scripts/cache.sh ]]; then
            supported=true
          else
            supported=false
          fi
          echo "supported=$supported" >> "$GITHUB_OUTPUT"

      - name: Restore ClamAV binaries
        id: clamav-binaries
        if: steps.clamav-cache.outputs.supported == 'true'
        uses: actions/cache/restore@v6
        with:
          path: ./applications/core/anti-virus/bin
          key: ${{ runner.os }}-${{ runner.arch }}-clamav-binaries-v3-${{ hashFiles('applications/core/anti-virus/build-inputs.env', 'applications/core/anti-virus/scripts/build.sh', 'applications/core/anti-virus/scripts/cache.sh') }}-${{ github.run_id }}-${{ github.run_attempt }}
          restore-keys: |
            ${{ runner.os }}-${{ runner.arch }}-clamav-binaries-v3-${{ hashFiles('applications/core/anti-virus/build-inputs.env', 'applications/core/anti-virus/scripts/build.sh', 'applications/core/anti-virus/scripts/cache.sh') }}-

      - name: Validate restored ClamAV binaries
        id: clamav-validation
        if: steps.clamav-cache.outputs.supported == 'true'
        env:
          CACHE_MATCHED_KEY: ${{ steps.clamav-binaries.outputs.cache-matched-key }}
          CACHE_STARTED_AT: ${{ steps.clamav-timing.outputs.cache-started-at }}
        run: |
          validation_started_at="$(date +%s)"
          restore_elapsed=$(( validation_started_at - CACHE_STARTED_AT ))
          if [[ -z "$CACHE_MATCHED_KEY" ]]; then
            cache_state="miss"
            valid=false
          elif applications/core/anti-virus/scripts/cache.sh validate; then
            cache_state="hit"
            valid=true
          else
            cache_state="invalid"
            valid=false
            rm -rf applications/core/anti-virus/bin
          fi
          validation_elapsed=$(( $(date +%s) - validation_started_at ))
          echo "valid=$valid" >> "$GITHUB_OUTPUT"
          echo "| ClamAV cache restore | ${restore_elapsed}s ($cache_state) |" >> "$RUNNER_TEMP/delivery-timing.md"
          echo "| ClamAV cache validation | ${validation_elapsed}s ($cache_state) |" >> "$RUNNER_TEMP/delivery-timing.md"

      - name: Build ClamAV binaries
        env:
          CACHE_VALID: ${{ steps.clamav-validation.outputs.valid }}
        run: |
          started_at="$(date +%s)"
          yarn workspace @core/anti-virus predeploy
          elapsed_seconds=$(( $(date +%s) - started_at ))
          if [[ "$CACHE_VALID" == "true" ]]; then
            route="cache hit"
          else
            route="source build"
          fi
          echo "| ClamAV source build ($route) | ${elapsed_seconds}s |" >> "$RUNNER_TEMP/delivery-timing.md"

      - name: Save rebuilt ClamAV binaries
        if: steps.clamav-cache.outputs.supported == 'true' && steps.clamav-validation.outputs.valid != 'true'
        uses: actions/cache/save@v6
        with:
          path: ./applications/core/anti-virus/bin
          key: ${{ steps.clamav-binaries.outputs.cache-primary-key }}

      - name: Package anti-virus
        run: |
          started_at="$(date +%s)"
          yarn workspace @core/anti-virus exec serverless package --stage $STAGE --package "$RUNNER_TEMP/anti-virus-package"
          elapsed_seconds=$(( $(date +%s) - started_at ))
          echo "| Anti-virus packaging | ${elapsed_seconds}s |" >> "$RUNNER_TEMP/delivery-timing.md"
