{
  "name": "@accounts/warm-up",
  "version": "0.0.0-development",
  "description": "Motech Development accounts warm up service",
  "scripts": {
    "formatting": "prettier . --check",
    "deploy": "serverless deploy --verbose",
    "lint": "eslint './src/**/*.ts'",
    "start": "serverless invoke stepf --name warmUp",
    "teardown": "serverless remove --verbose",
    "test": "jest --watch",
    "test-ci": "jest --coverage --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "3.1033.0",
    "@aws-sdk/lib-dynamodb": "3.1033.0",
    "@motech-development/node-logger": "workspace:*",
    "@sentry/aws-serverless": "10.48.0",
    "@sentry/profiling-node": "10.48.0",
    "luxon": "3.5.0",
    "uuid": "9.0.1",
    "yup": "1.4.0"
  },
  "devDependencies": {
    "@motech-development/eslint-config-motech-base": "workspace:*",
    "@motech-development/prettier-motech-config": "workspace:*",
    "@motech-development/semantic-release": "workspace:*",
    "@swc/core": "1.11.5",
    "@swc/jest": "0.2.37",
    "@types/aws-lambda": "8.10.147",
    "@types/jest": "29.5.14",
    "@types/luxon": "3.4.2",
    "@types/uuid": "9.0.8",
    "aws-lambda-mock-context": "3.2.1",
    "aws-sdk-client-mock": "4.1.0",
    "aws-sdk-client-mock-jest": "4.1.0",
    "esbuild": "0.28.1",
    "eslint": "9.37.0",
    "jest": "29.7.0",
    "jest-date-mock": "1.0.10",
    "jest-watch-typeahead": "2.2.2",
    "osls": "3.63.2",
    "prettier": "3.2.5",
    "serverless-deployment-bucket": "1.6.0",
    "serverless-esbuild": "1.57.2",
    "serverless-prune-plugin": "2.1.0",
    "serverless-step-functions": "3.29.1",
    "typescript": "6.0.3"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.ts"
    ],
    "testEnvironment": "node",
    "transform": {
      "^.+\\.(t|j)sx?$": "@swc/jest"
    },
    "watchPlugins": [
      "jest-watch-typeahead/filename",
      "jest-watch-typeahead/testname"
    ]
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "src/**/*.{ts,tsx}": "eslint --fix"
  }
}
