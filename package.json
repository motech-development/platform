{
  "name": "platform",
  "version": "0.0.0",
  "description": "Motech Development applications monorepo",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "clean-deps": "find . -name node_modules -exec rm -rf {} \\;",
    "clean-git": "git branch --merged | egrep -v \"(^\\*|main|develop)\" | xargs git branch -d",
    "commit": "cz",
    "format": "pnpm -r exec prettier --ignore-unknown --write .",
    "format-root": "pnpm exec prettier --ignore-unknown --write .",
    "lint": "pnpm -r --if-present run lint",
    "package": "pnpm -r --if-present run package",
    "prepare": "is-ci || husky",
    "release": "multi-semantic-release",
    "test": "pnpm -r --if-present run test-ci"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/motech-development/platform.git"
  },
  "author": "Mo Gusbi <mo.gusbi@motechdevelopment.co.uk> (https://motechdevelopment.co.uk)",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/motech-development/platform/issues"
  },
  "homepage": "https://github.com/motech-development/platform#readme",
  "devDependencies": {
    "@commitlint/cli": "19.7.1",
    "@commitlint/config-conventional": "19.7.1",
    "@motech-development/prettier-motech-config": "workspace:*",
    "@motech-development/semantic-release": "workspace:*",
    "@qiwi/multi-semantic-release": "7.1.2",
    "@types/is-ci": "3.0.4",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "esbuild": "0.25.0",
    "husky": "9.1.7",
    "is-ci": "3.0.1",
    "lint-staged": "15.4.3",
    "prettier": "3.2.5",
    "renovate": "36.109.4",
    "typescript": "5.8.2"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  },
  "pnpm": {
    "patchedDependencies": {
      "serverless-esbuild@1.57.0": "patches/serverless-esbuild@1.57.0.patch"
    }
  }
}
