{
  "name": "@motech-development/appsync-apollo",
  "version": "0.0.0-development",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/motech-development/platform.git"
  },
  "description": "React Apollo client configured for AppSync",
  "author": "Mo Gusbi <mo.gusbi@motechdevelopment.co.uk> (https://motechdevelopment.co.uk)",
  "bugs": {
    "url": "https://github.com/motech-development/platform/issues"
  },
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "scripts": {
    "formatting": "prettier . --check",
    "build": "run prebuild && vite build && tsc --project tsconfig.build.json --emitDeclarationOnly",
    "lint": "eslint './src/**/*.{ts,tsx}'",
    "package": "run build",
    "prebuild": "rimraf ./lib",
    "test": "jest --watch",
    "test-ci": "jest --coverage --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "aws-appsync-auth-link": "3.0.7",
    "aws-appsync-subscription-link": "3.1.3"
  },
  "devDependencies": {
    "@apollo/client": "3.13.1",
    "@motech-development/eslint-config-motech-react": "workspace:*",
    "@motech-development/prettier-motech-config": "workspace:*",
    "@motech-development/semantic-release": "workspace:*",
    "@swc/core": "1.11.5",
    "@swc/jest": "0.2.37",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.2.0",
    "@types/jest": "29.5.14",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "6.0.4",
    "eslint": "9.37.0",
    "graphql": "16.10.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jest-watch-typeahead": "2.2.2",
    "prettier": "3.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rimraf": "6.0.1",
    "typescript": "6.0.3",
    "unfetch": "5.0.0",
    "vite": "8.1.5"
  },
  "peerDependencies": {
    "@apollo/client": "^3.13.1",
    "graphql": "^16.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.stories.{ts,tsx}"
    ],
    "moduleNameMapper": {
      "^uuid$": "uuid"
    },
    "setupFilesAfterEnv": [
      "<rootDir>/src/setupTests.ts"
    ],
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.(t|j)sx?$": [
        "@swc/jest",
        {
          "jsc": {
            "transform": {
              "react": {
                "runtime": "automatic"
              }
            }
          }
        }
      ]
    },
    "watchPlugins": [
      "jest-watch-typeahead/filename",
      "jest-watch-typeahead/testname"
    ]
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "src/**/*.{ts,tsx}": "eslint --fix"
  }
}
