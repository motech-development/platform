{
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "lib",
    "rootDir": "src"
  },
  "exclude": [
    "lib",
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/setupTests.ts"
  ],
  "extends": "./tsconfig.json",
  "include": ["src"]
}
