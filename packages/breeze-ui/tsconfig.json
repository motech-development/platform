{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2024"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["node", "vitest/globals"]
  },
  "exclude": ["dist", "lib", "storybook-static"],
  "include": [
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "src",
    "test",
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
