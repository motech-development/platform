{
  "name": "@motech-development/breeze-ui",
  "version": "0.0.0-development",
  "description": "Accessible, domain-neutral UI primitives and patterns for Motech applications",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/motech-development/platform.git"
  },
  "author": "Mo Gusbi <mo.gusbi@motechdevelopment.co.uk> (https://motechdevelopment.co.uk)",
  "bugs": {
    "url": "https://github.com/motech-development/platform/issues"
  },
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons.js"
    },
    "./styles.css": "./dist/styles.css",
    "./reset.css": "./dist/reset.css"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "formatting": "prettier . --check",
    "build": "vite build && tsc --project tsconfig.build.json --emitDeclarationOnly",
    "build-storybook": "storybook build",
    "deploy": "yarn build-storybook",
    "lint": "eslint .",
    "package": "yarn build",
    "storybook": "storybook dev --port 6006",
    "test": "vitest run --project unit",
    "test-ci": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@internationalized/date": "3.12.2",
    "lucide-react": "1.23.0",
    "react-aria": "3.50.0",
    "react-aria-components": "1.19.0",
    "remark-gfm": "4.0.1",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "3.2.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.2.1",
    "@fontsource-variable/cabin": "5.2.8",
    "@motech-development/eslint-config-motech-react": "workspace:*",
    "@motech-development/prettier-motech-config": "workspace:*",
    "@motech-development/semantic-release": "workspace:*",
    "@storybook/addon-a11y": "10.4.6",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "9.37.0",
    "jsdom": "29.1.1",
    "playwright": "1.61.1",
    "prettier": "3.2.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "storybook": "10.4.6",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "src/**/*.{ts,tsx}": "eslint --fix"
  }
}
