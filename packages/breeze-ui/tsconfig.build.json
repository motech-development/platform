{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src"
  },
  "exclude": [
    ".storybook",
    "dist",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "storybook-static",
    "test",
    "vite.config.ts",
    "vitest.config.ts"
  ],
  "include": ["src"]
}
