{
  "name": "@motech-development/webpack-permissions-plugin",
  "version": "0.0.0-development",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/motech-development/platform.git"
  },
  "description": "A Webpack plugin to set permissions for your output files and folders",
  "author": "Mo Gusbi <mo.gusbi@motechdevelopment.co.uk> (https://motechdevelopment.co.uk)",
  "bugs": {
    "url": "https://github.com/motech-development/platform/issues"
  },
  "license": "ISC",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "lib"
  ],
  "main": "lib/webpack-permissions-plugin.cjs.js",
  "module": "lib/webpack-permissions-plugin.esm.js",
  "types": "lib/webpack-permissions-plugin.d.ts",
  "scripts": {
    "formatting": "prettier . --check",
    "build": "run prebuild && vite build && tsc --project tsconfig.build.json --emitDeclarationOnly",
    "lint": "eslint './src/**/*.ts'",
    "package": "run build",
    "prebuild": "rimraf ./lib",
    "test": "jest --watch",
    "test-ci": "jest --coverage --runInBand",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "filehound": "1.17.6"
  },
  "devDependencies": {
    "@motech-development/eslint-config-motech-base": "workspace:*",
    "@motech-development/prettier-motech-config": "workspace:*",
    "@motech-development/semantic-release": "workspace:*",
    "@swc/core": "1.11.5",
    "@swc/jest": "0.2.37",
    "@types/jest": "29.5.14",
    "eslint": "9.37.0",
    "jest": "29.7.0",
    "jest-watch-typeahead": "2.2.2",
    "prettier": "3.2.5",
    "rimraf": "6.0.1",
    "tapable": "2.3.3",
    "typescript": "6.0.3",
    "vite": "8.1.5",
    "webpack": "5.96.1"
  },
  "peerDependencies": {
    "webpack": "^5.96.1"
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts"
    ],
    "testEnvironment": "node",
    "transform": {
      "^.+\\.(t|j)sx?$": "@swc/jest"
    },
    "watchPlugins": [
      "jest-watch-typeahead/filename",
      "jest-watch-typeahead/testname"
    ]
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write",
    "src/**/*.{ts,tsx}": "eslint --fix"
  }
}
